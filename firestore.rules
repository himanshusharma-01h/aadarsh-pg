rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'himanshusharmasharmaa01@gmail.com' ||
        request.auth.token.email == 'admin@aadarsh.com'
      );
    }

    // Rooms rules - Allow read and write for seamless seeding/updating
    match /rooms/{roomId} {
      allow read, write: if true;
    }

    // Gallery rules - Allow read and write for seamless seeding/updating
    match /gallery/{galleryId} {
      allow read, write: if true;
    }

    // Testimonials rules - Allow read and write for seamless seeding/updating
    match /testimonials/{testimonialId} {
      allow read, write: if true;
    }

    // Menus rules - Allow read and write for seamless seeding/updating
    match /menus/{menuId} {
      allow read, write: if true;
    }

    // Inquiries rules - Allow guest creation, admin reads/updates
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if true; // Allow client operations to ensure reliable testing
    }
  }
}
